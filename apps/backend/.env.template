# apps/backend — kopieren nach .env  (Medusa laedt .env aus diesem Verzeichnis)
# Lokale DB starten:  docker compose up -d   (im Repo-Root)

DATABASE_URL=postgres://medusa:medusa@localhost:15432/medusa
REDIS_URL=redis://localhost:16379

STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000

# Lokale Dev-Geheimnisse — fuer Prod ueber Coolify-ENV setzen (Vault: Secrets-Management.md)
JWT_SECRET=supersecret-dev-only
COOKIE_SECRET=supersecret-dev-only

# Logging / Observability (Sprint 6, ADR-012 + ADR-013)
# - LOG_LEVEL: fatal|error|warn|info|debug|trace|silent   (default: info)
#   Lokal optional `debug` setzen; CI/Prod auf `info` lassen (sonst Log-Lawine).
# - LOGTAIL_SOURCE_TOKEN: BetterStack-Source-Token. LEER = no-op (kein Transport).
#   Lokal NIE setzen; Prod ueber Coolify-ENV (Vault: Secrets-Management.md).
LOG_LEVEL=info
LOGTAIL_SOURCE_TOKEN=
