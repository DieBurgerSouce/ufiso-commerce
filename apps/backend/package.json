{
  "name": "@ufiso/backend",
  "version": "0.0.0",
  "private": true,
  "description": "UFISO Medusa v2 Backend — ein Sales Channel pro Shop, Odoo als SoT fuer Inventar.",
  "license": "UNLICENSED",
  "scripts": {
    "build": "medusa build",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "seed:products": "medusa exec ./src/scripts/seed-mock-products.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "db:migrate": "medusa db:migrate",
    "typecheck": "tsc --noEmit",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@logtail/pino": "^0.5.8",
    "@medusajs/admin-sdk": "2.15.3",
    "@medusajs/cli": "2.15.3",
    "@medusajs/framework": "2.15.3",
    "@medusajs/medusa": "2.15.3",
    "ioredis": "^5.10.1",
    "pino": "^9.14.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.3",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "pino-pretty": "^11.3.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
