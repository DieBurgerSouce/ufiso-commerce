# apps/storefront-tropfshop — kopieren nach .env.local
# Secrets NIE committen (Vault: Secrets-Management.md)

# Medusa-Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Publishable API Key — Ausgabe des Backend-Seeds (pnpm --filter @ufiso/backend seed)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Brevo Newsletter (Double-Opt-In) — Werte aus dem Brevo-Account
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_DOI_TEMPLATE_ID=
# Dev: http://localhost:3000/newsletter-bestaetigt
# Prod: https://tropfshop.de/newsletter-bestaetigt
BREVO_DOI_REDIRECT_URL=http://localhost:3000/newsletter-bestaetigt

# Logging / Observability (Sprint 6, ADR-012 + ADR-013)
# - LOG_LEVEL: fatal|error|warn|info|debug|trace|silent  (default: info)
# - LOGTAIL_SOURCE_TOKEN: BetterStack-Source-Token. LEER = no-op.
#   Lokal nie setzen; Prod via Coolify-ENV (Vault: Secrets-Management.md).
#   Storefront-Source ist getrennt vom Backend-Source.
LOG_LEVEL=info
LOGTAIL_SOURCE_TOKEN=
