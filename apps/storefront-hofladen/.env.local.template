# apps/storefront-hofladen — kopieren nach .env.local
# Secrets NIE committen (Vault: Secrets-Management.md, ADR-015 Anti-Patterns)

# Medusa-Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Publishable API Key — Ausgabe des Backend-Seeds, Wert aus
# apps/backend/.seed-output.json -> shops.hofladen.publishableKey
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Brevo Newsletter (Double-Opt-In) — Werte aus dem Brevo-Account
# Sprint 11 C.3 nutzt EIGENE Listen-ID pro Brand (zwei separate
# Listen "Tropfshop Newsletter" + "Hofladen Newsletter" in Brevo).
BREVO_API_KEY=
BREVO_HOFLADEN_LIST_ID=
BREVO_DOI_TEMPLATE_ID=
# Dev: http://localhost:3001/newsletter-bestaetigt
# Prod: https://<hofladen-domain>/newsletter-bestaetigt
BREVO_DOI_REDIRECT_URL=http://localhost:3001/newsletter-bestaetigt

# Logging / Observability (ADR-012 + ADR-013)
LOG_LEVEL=info
LOGTAIL_SOURCE_TOKEN=
