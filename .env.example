# ── UFISO Monorepo — Env-Vorlage ────────────────────────────────────────────
# Kopieren nach .env (Backend) bzw. apps/storefront-tropfshop/.env.local
# Secrets NIE committen — siehe Vault: Secrets-Management.md
# Lokal empfohlen: op run --env-file=.env.example -- pnpm dev (1Password CLI)

# ── Backend (apps/backend) ───────────────────────────────────────────────────
# Lokal: docker compose up -d  -> Postgres auf Port 15432
DATABASE_URL=postgres://medusa:medusa@localhost:15432/medusa
REDIS_URL=redis://localhost:16379
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000,http://localhost:9000
JWT_SECRET=supersecret-dev-only
COOKIE_SECRET=supersecret-dev-only

# ── Storefront (apps/storefront-tropfshop) ──────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Brevo Newsletter (Pre-Launch-Capture) — API-Key aus Brevo-Account
# op://Tropfshop/Brevo/api-key
BREVO_API_KEY=
# Brevo Kontaktlisten-ID "Tropfshop Newsletter"
BREVO_NEWSLETTER_LIST_ID=
