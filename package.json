{
  "name": "ufiso-commerce",
  "version": "0.0.0",
  "private": true,
  "description": "UFISO Multi-Shop E-Commerce Monorepo — erster Shop: Tropfshop",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "backend:dev": "turbo run dev --filter=@ufiso/backend",
    "storefront:dev": "turbo run dev --filter=@ufiso/storefront-tropfshop"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  }
}
